{
  "name": "motion-slice",
  "productName": "motion-slice",
  "version": "0.0.1",
  "description": "MotionSlice - Video slicing and shake detection tool",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "chcp 65001 && electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "electron-forge make --targets=@electron-forge/maker-squirrel",
    "make:mac": "electron-forge make --targets=@electron-forge/maker-dmg",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx ."
  },
  "keywords": [],
  "author": {
    "name": "thb",
    "email": "haobo0430@163.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "42.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^9.33.0",
    "typescript": "~5.3.0",
    "vite": "^5.4.21",
    "vue-eslint-parser": "^9.4.3"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.34"
  }
}
